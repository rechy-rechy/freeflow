# Anthropic API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Canvas LMS
# API URL: your school's Canvas domain, e.g. https://school.instructure.com
CANVAS_API_URL=https://yourschool.instructure.com
# API Token: Canvas → Account → Settings → Approved Integrations → New Access Token
CANVAS_API_TOKEN=your_canvas_api_token_here

# Google (OAuth credentials from Google Cloud Console)
# See SETUP.md for how to create these
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Your school email address
SCHOOL_EMAIL=yourname@school.edu
